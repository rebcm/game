{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bloco Documentation",
  "type": "object",
  "properties": {
    "blocos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "nome": {"type": "string"},
          "descricao": {"type": "string"}
        },
        "required": ["id", "nome", "descricao"]
      }
    }
  },
  "required": ["blocos"]
}
