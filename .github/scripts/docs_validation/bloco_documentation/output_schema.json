{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Block Documentation Output",
  "type": "object",
  "properties": {
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"}
        },
        "required": ["id", "name", "description"]
      }
    }
  },
  "required": ["blocks"]
}
